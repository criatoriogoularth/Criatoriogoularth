# Copie este arquivo para ".env" e preencha com valores reais.
# NUNCA commite o .env de verdade — ele já está no .gitignore.

# String de conexão do Postgres (rotacione a senha antes de usar aqui,
# já que a antiga foi exposta).
DATABASE_URL=postgresql://usuario:senha@host/nome_do_banco

# Gere um valor aleatório longo, por exemplo com:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-um-valor-aleatorio-longo-e-secreto

PORT=3000

# URL do site em produção (restringe o CORS). Deixe vazio em dev local.
FRONTEND_ORIGIN=

# "false" desativa SSL na conexão com o Postgres (só use false em Postgres local sem SSL)
PGSSL=true
